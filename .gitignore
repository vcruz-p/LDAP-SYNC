```gitignore
# Build artifacts
bin/
obj/
*.dll
*.exe
*.pdb
*.so
*.dylib
*.class

# Dependencies
packages/
node_modules/
.nuget/

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db

# Environment specific
.env
.env.local
*.env.*

# IDE
.vscode/
.idea/
*.swp
*.swo

# Testing
TestResults/
coverage/
*.coverage

# Distribution
dist/
build/
target/
```